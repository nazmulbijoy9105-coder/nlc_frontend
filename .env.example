# NLC Frontend — Environment Variables
# Set these in the Vercel project environment.

# Your NLC backend URL on Render. The proxy accepts this name plus the
# existing Vercel names NEXT_PUBLIC_BACKEND_URL and NEXT_PUBLIC_API_BASE_URL.
# Browser API calls go through /api/backend first, so the frontend is not
# dependent on backend CORS configuration.
NEXT_PUBLIC_API_URL=https://nlc-platform.onrender.com

# Optional: override the same-origin frontend proxy path.
# NEXT_PUBLIC_API_BASE_PATH=/api/backend

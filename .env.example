# NLC Frontend — Environment Variables
# Copy to .env.local and fill in values

# Your NLC backend URL on Render. Browser API calls go through /api/backend
# first, so the frontend is not dependent on backend CORS configuration.
NEXT_PUBLIC_API_URL=https://nlc-platform.onrender.com

# Optional: override the same-origin frontend proxy path.
# NEXT_PUBLIC_API_BASE_PATH=/api/backend
